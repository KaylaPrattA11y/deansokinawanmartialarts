---
interface ButtonProps {
  href?: string;
  variant?: 'primary' | 'secondary';
  size?: 'sm' | 'md';
  width?: 'auto' | 'full';
}
const { href, variant = 'primary', size = 'md', width = 'auto', ...rest } = Astro.props as ButtonProps;
---
{href ? (
  <a href={href} class={`btn-${variant} is-${size} is-${width}`} {...rest}><slot /></a>
) :(
  <button class={`btn-${variant} is-${size} is-${width}`} {...rest}><slot /></button>
)}

<style>
@layer components {
  button {
    appearance: none;
    margin: 0;
    border: 0;
    background: none;
  }
  :is(a, button) {
    display: inline-block;
    font-family: var(--ff-heading);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    text-align: center;
    box-sizing: border-box;
    line-height: normal;
  }
  @media (max-width: 600px) {
    :is(a, button) {
      inline-size: 100%;
    }
  }
  :is(a, button).is-md {
    padding: 0.95rem 2.8rem;
  }
  :is(a, button).is-sm {
    padding: 0.5rem 1.5rem;
  }
  :is(a, button).is-full {
    inline-size: 100%;
  }
  :is(a, button):has(svg) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-primary {
    color: var(--paper);
    background: var(--deep-red);
    border: 1px solid rgba(194, 189, 181, 0.15);
  }
  .btn-secondary {
    color: var(--silver);
    border: 1px solid rgba(194, 189, 181, 0.3);
  }
  .btn-primary::after {
    content: '';
    position: absolute;
    inset: 3px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    pointer-events: none;
  }
  .btn-primary:hover {
    background: var(--bright-red);
    color: var(--paper);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(139, 21, 21, 0.5);
    border-color: var(--silver);
  }
  .btn-secondary:hover {
    border-color: var(--silver);
    color: var(--paper);
    background: rgba(194, 189, 181, 0.07);
  }
}
</style>