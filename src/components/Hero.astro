---
import { Image } from "astro:assets";
import logo from "../assets/logo.svg";
import Button from "./Button.astro";
---

<section aria-labelledby="main-content-anchor" class="hero fade-in" id="hero">
  <div class="hero-content">
    <div>
      <div class="hero-logo">
        <Image src={logo} alt="Dojo seal" width={125} height={125} fetchpriority="high" />
      </div>
      <div class="hero-kana">沖縄武道 · Okinawa Budō</div>
      <h1 class="hero-heading" id="main-content-anchor">Dean's <div>Okinawan</div> Martial Arts</h1>
      <div class="short-divider" />
      <p class="hero-sub">Shorin-Ryu Matsumura Seito · Hollywood, Maryland</p>
      <div class="hero-tenets">
        <span>Character</span>
        <span>Sincerity</span>
        <span>Effort</span>
        <span>Etiquette</span>
        <span>Self-Control</span>
      </div>
      <div role="group" class="hero-buttons">
        <Button 
          type="button" 
          variant="primary" 
          aria-haspopup="dialog" 
          aria-controls="free-trial-dialog"
        >
          Start Free Trial
        </Button>
        <Button type="button" variant="secondary" data-anchor="classes">View Schedule</Button>
      </div>
    </div>
  </div>
</section>

<script>
  const heroSection = document.getElementById('hero');

  heroSection?.addEventListener('click', event => {
    if (event.target instanceof HTMLButtonElement && event.target.getAttribute('aria-controls') === 'free-trial-dialog') {
      const dialog = document.getElementById('free-trial-dialog') as HTMLDialogElement;
      const contactForm = document.forms.namedItem('contact-form') as HTMLFormElement;
      const messageTextarea = document.getElementById('message') as HTMLTextAreaElement;

      contactForm.reset();
      dialog?.showModal();
      if (messageTextarea) {
        messageTextarea.value = 'I am interested in the 7-Day Free Trial.';
      }
      contactForm.dispatchEvent(new Event('change', { bubbles: true }));
    }
  });
</script>

<style>
	@layer components {
    .hero {
      text-align: center;
      min-height: calc(100vh - var(--header-height));
      display: grid;
      gap: 1em;
      place-items: center;
      align-content: start;
      position: relative;
      overflow: hidden;
    }
    .hero-content {
      padding: 3rem 1rem;
      box-sizing: border-box;
      @media (min-height: 900px) {
        display: grid;
        place-content: center;
        block-size: calc(100dvh - var(--header-height));
        padding-block: 0;
      }
    }
    .hero-logo > img {
      -webkit-box-reflect: var(--reflect-below);
    }
    .hero-heading {
      font-family: var(--ff-heading);
      font-size: clamp(2.5rem, 7vw, 6rem);
      font-weight: 900;
      line-height: 0.95;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--paper);
      margin: 0;
    }
    .hero-heading > div {
      display: block;
      color: var(--deep-red);
      font-size: clamp(1.6rem, 4.5vw, 4rem);
      letter-spacing: 0.15em;
    }
    .hero-kana {
      font-family: var(--ff-jp);
      font-size: 0.85rem;
      letter-spacing: 0.5em;
      color: var(--silver);
      margin-block: .5rem 1.5rem;
    }
    .hero-sub {
      font-family: var(--ff-heading);
      font-size: clamp(0.9rem, 1.4vw, 0.82rem);
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--cream);
      margin-bottom: 3rem;
    }
    .hero-tenets {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 3.5rem;
    }
    .hero-tenets span {
      font-family: var(--ff-body);
      font-style: italic;
      font-size: 0.9rem;
      color: var(--cream);
      letter-spacing: 0.05em;
    }
    .hero-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem 2rem;
      justify-content: center;
    }
	}
</style>
