---
import { Icon } from 'astro-icon/components';
import { type IKarateClass } from '../constants';

interface IKarateClassProps {
  karateClass: IKarateClass;
  id: string; // unique ID for this instance (e.g. "youth-class-1")
  cancelledDates?: string[]; // array of YYYY-MM-DD strings for cancelled class dates
  headingLevel?: number; // optional heading level for the class name (1-6). If not provided, defaults to no heading. Should be used to maintain proper document structure when this component is used within a page.
}

const { karateClass, id, cancelledDates = [], headingLevel = 0 } = Astro.props as IKarateClassProps;

function buildGoogleCalendarLinkTemplate(cls: IKarateClass): string {
  const dayNumberToRRule: Record<number, string> = {
    0: "SU", 1: "MO", 2: "TU", 3: "WE", 4: "TH", 5: "FR", 6: "SA",
  };
  const byDay = cls.recurrence_byDay.map((d) => dayNumberToRRule[d]).join(",");
  const rrule = `RRULE:FREQ=${cls.recurrence.toUpperCase()};BYDAY=${byDay}`;
  // Build params without dates — client appends &dates=... directly to avoid double-encoding
  const params = new URLSearchParams({
    action: "TEMPLATE",
    text: `${cls.name} - Dean's Okinawan Martial Arts`,
    details: cls.description,
    location: cls.location,
    recur: rrule,
  });
  return `https://calendar.google.com/calendar/render?${params.toString()}&dates=__DATES__`;
}

function formatMilitaryToStandard(militaryTime: string) {
  const [hours, minutes, seconds] = militaryTime.split(':');
  const dateObj = new Date();
  dateObj.setHours(Number(hours), Number(minutes), Number(seconds) || 0);
  return dateObj.toLocaleTimeString('en-US', { hour: 'numeric', hour12: true });
}
---

<div
  class="calendar"
  data-component="CalendarAddKarateClass"
  data-ics-name={karateClass.name}
  data-class={JSON.stringify(karateClass)}
  data-cancelled-dates={JSON.stringify(cancelledDates)}
  data-id={id}
  data-google-link-template={buildGoogleCalendarLinkTemplate(karateClass)}
>
  <div>
    <div class="calendar--date" style="visibility: hidden;" data-slot="date-panel">
      <span class="calendar--date-next">Next class:</span>
      <span class="calendar--date-day" data-slot="day"></span>
      <span class="calendar--date-month" data-slot="month"></span>
    </div>
    <div class="calendar--event-details">
      {headingLevel === 1 ? (
        <h1 class="calendar--event-title"><span>{karateClass.name}</span></h1>
      ) : headingLevel === 2 ? (
        <h2 class="calendar--event-title"><span>{karateClass.name}</span></h2>
      ) : headingLevel === 3 ? (
        <h3 class="calendar--event-title"><span>{karateClass.name}</span></h3>
      ) : headingLevel === 4 ? (
        <h4 class="calendar--event-title"><span>{karateClass.name}</span></h4>
      ) : headingLevel === 5 ? (
        <h5 class="calendar--event-title"><span>{karateClass.name}</span></h5>
      ) : headingLevel === 6 ? (
        <h6 class="calendar--event-title"><span>{karateClass.name}</span></h6>
      ) : null}
      <div class="calendar--event-location"><Icon name="location" size={16} /> <span>{karateClass.location}</span></div>
      <div class="calendar--recurrence">
        <Icon name="calendar-week" size={14} /> <span>{karateClass.recurrence}: {karateClass.schedule}</span>
      </div>
      <div class="calendar--event-time">
        <Icon name="clock" size={14} /> <span>{formatMilitaryToStandard(karateClass.startTime)} - {formatMilitaryToStandard(karateClass.endTime)}</span>
      </div>
    </div>
    <div class="calendar--controls">
      <button
        type="button"
        aria-label={`Add ${karateClass.name} to calendar`}
        title={`Add ${karateClass.name} to calendar`}
        class="calendar--add"
        data-toggle="calendar-dropdown"
        aria-expanded="false"
        aria-controls={`calendarDropdownMenu-${id}`}
        id={`calendarToggleDropdown-${id}`}
      >
        <Icon name="calendar-plus" color="var(--paper)" size={22} />
      </button>
      <div class="calendar--dropdown" role="menu" id={`calendarDropdownMenu-${id}`} data-component="dropdown">
        <a
          href="#"
          target="_blank"
          class="calendar--dropdown-item"
          role="menuitem"
          data-slot="google-calendar-link"
        >
          <Icon name="google-calendar" size={18} /> Add to Google Calendar
        </a>
        <button
          type="button"
          class="calendar--dropdown-item"
          role="menuitem"
          data-action="download-ics"
          data-ics-id={id}
        >
          <Icon name="apple" size={18} /> Add to Apple Calendar
        </button>
        <button
          type="button"
          class="calendar--dropdown-item"
          role="menuitem"
          data-action="download-ics"
          data-ics-id={id}
        >
          <Icon name="download" size={18} /> Download .ICS
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .calendar {
    container: calendar / inline-size;
  }
  .calendar > div {
    position: relative;
    display: grid;
    align-content: center;
    line-height: 1.4;
    @container (width >= 250px) {
      grid-template-columns: minmax(100px, 0.25fr) 1fr;
    }
  }
  .calendar--date {
    display: grid;
    place-content: center;
    text-align: center;
    background-color: var(--deep-red);
    font-family: var(--ff-heading);
    padding: 0.5rem;
    box-sizing: border-box;
    overflow: hidden;
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
    line-height: 1;
    color: var(--paper);
  }
  .calendar--date-next {
    font-weight: 300;
    font-size: 0.8rem;
  }
  .calendar--date-day {
    text-transform: uppercase;
    font-weight: 700;
    font-size: 1.5rem;
  }
  .calendar--date-month {
    text-transform: uppercase;
    font-size: 1rem;
  }
  .calendar--event-details {
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    block-size: 100%;
    background-color: var(--stone);
    color: var(--paper);
    padding: 0.5rem;
    box-sizing: border-box;
  }
  .calendar--event-title {
    font-family: var(--ff-heading);
    font-size: 1.25rem;
    font-weight: 700;
    margin-block: 0 0.75rem;
    line-height: 1.2;
    margin-block-end: 0.25em;
  }
  :where(.calendar--event-location, .calendar--event-time, .calendar--recurrence) {
    color: var(--silver);
    font-size: 0.95rem;
  }
  .calendar--controls {
    position: absolute;
    inset: 0;
  }
  .calendar--dropdown {
    --anim-speed: 250ms;
    inline-size: 100%;
    display: none;
    opacity: 0;
    position: absolute;
    z-index: 99;
    background-color: var(--stone);
    border-radius: 4px;
    transition-duration: var(--anim-speed);
    transition-property: display, opacity;
    transition-behavior: allow-discrete;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    border: 1px solid rgba(194,189,181,0.3);
    border-inline-start: 0;
  }
  .calendar--dropdown [role="menuitem"] {
    appearance: none;
    margin: 0;
    border: 0;
    background: none;
    text-align: left;
    cursor: pointer;
    padding: 0.75rem 1rem;
    font-family: var(--ff-heading);
    font-size: 0.9rem;
    color: var(--paper);
    text-decoration: none;
    border-inline-start: 3px solid var(--deep-red);
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .calendar--dropdown [role="menuitem"]:hover {
    text-decoration: underline;
  }
  .calendar--dropdown [role="menuitem"]:not(:last-child) {
    border-block-end: 1px solid rgba(194,189,181,0.3);
  }
  .calendar--dropdown.is-expanded {
    display: grid;
    opacity: 1;
    @starting-style {
      opacity: 0;
    }
  }
  .calendar--add {
    background: none;
    appearance: none;
    margin: 0;
    padding: 0;
    border: none;
    cursor: pointer;
    inline-size: 100%;
    block-size: 100%;
  }
  .calendar--add svg {
    position: absolute;
    inset: auto 2px 2px auto;
    pointer-events: none;
  }
  .calendar--event-details > div:has(svg) {
    display: grid;
    gap: 0.1rem;
    align-items: center;
    grid-template-columns: 20px 1fr;
  }
  .calendar--event-details span {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    overflow: hidden;
  }
</style>

<script>
  interface ESTDate {
    year: number;
    month: number; // 0-indexed
    day: number;
    dayOfWeek: number; // 0 = Sunday
  }

  function getTodayEST(): ESTDate {
    const now = new Date();
    const formatter = new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/New_York',
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      weekday: 'short',
    });
    const parts = formatter.formatToParts(now);
    const year    = Number(parts.find(p => p.type === 'year')?.value);
    const month   = Number(parts.find(p => p.type === 'month')?.value) - 1;
    const day     = Number(parts.find(p => p.type === 'day')?.value);
    const weekday = parts.find(p => p.type === 'weekday')?.value ?? 'Sun';
    const dayOfWeek = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].indexOf(weekday);
    return { year, month, day, dayOfWeek };
  }

  // Build a plain Date from EST y/m/d + hour/minute, in local time.
  // Only used for display and ICS formatting — never for day-of-week math.
  function makeLocalDate(estDate: ESTDate, hours: number, minutes: number): Date {
    const d = new Date(estDate.year, estDate.month, estDate.day, hours, minutes, 0, 0);
    return d;
  }

  function addDays(base: ESTDate, n: number): ESTDate {
    // Use a UTC-noon anchor to safely add days without DST shifting the date
    const anchor = new Date(Date.UTC(base.year, base.month, base.day, 12, 0, 0));
    anchor.setUTCDate(anchor.getUTCDate() + n);
    return {
      year: anchor.getUTCFullYear(),
      month: anchor.getUTCMonth(),
      day: anchor.getUTCDate(),
      dayOfWeek: (base.dayOfWeek + n) % 7,
    };
  }

  function toDateString(d: ESTDate): string {
    return d.year + '-' +
      String(d.month + 1).padStart(2, '0') + '-' +
      String(d.day).padStart(2, '0');
  }

  function fmt(d: Date): string {
    return d.getFullYear().toString() +
      String(d.getMonth() + 1).padStart(2, '0') +
      String(d.getDate()).padStart(2, '0') + 'T' +
      String(d.getHours()).padStart(2, '0') +
      String(d.getMinutes()).padStart(2, '0') + '00';
  }

  interface Occurrence {
    startDT: Date;
    endDT: Date;
    estDate: ESTDate;
  }

  function getNextOccurrence(
    recurrenceByDay: number[],
    startTime: string,
    endTime: string,
    cancelledDates: string[],
  ): Occurrence {
    const cancelledSet = new Set(cancelledDates);
    const today = getTodayEST();
    const [sh, sm] = startTime.split(':').map(Number);
    const [eh, em] = endTime.split(':').map(Number);

    // Offsets from today (0 = today) for each recurring day
    const dayOffsets = recurrenceByDay
      .map(d => (d - today.dayOfWeek + 7) % 7)
      .sort((a, b) => a - b);

    for (let week = 0; week < 52; week++) {
      for (const offset of dayOffsets) {
        const candidate = addDays(today, offset + week * 7);
        if (!cancelledSet.has(toDateString(candidate))) {
          return {
            startDT: makeLocalDate(candidate, sh, sm),
            endDT:   makeLocalDate(candidate, eh, em),
            estDate: candidate,
          };
        }
      }
    }

    // Fallback: nearest day regardless of cancellation
    const fallback = addDays(today, dayOffsets[0]);
    return {
      startDT: makeLocalDate(fallback, sh, sm),
      endDT:   makeLocalDate(fallback, eh, em),
      estDate: fallback,
    };
  }

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  function generateICSContent(cls: any, id: string, cancelledDates: string[]): string {
    const dayNumberToRRule: Record<number, string> = {
      0: "SU", 1: "MO", 2: "TU", 3: "WE", 4: "TH", 5: "FR", 6: "SA",
    };
    const { startDT, endDT } = getNextOccurrence(
      cls.recurrence_byDay, cls.startTime, cls.endTime, cancelledDates
    );

    const uid = `${id}-${fmt(startDT)}@deans-okinawan-martial-arts`;
    const now = new Date();
    const dtstamp =
      now.getUTCFullYear().toString() +
      String(now.getUTCMonth() + 1).padStart(2, '0') +
      String(now.getUTCDate()).padStart(2, '0') + 'T' +
      String(now.getUTCHours()).padStart(2, '0') +
      String(now.getUTCMinutes()).padStart(2, '0') +
      String(now.getUTCSeconds()).padStart(2, '0') + 'Z';

    const byDay = cls.recurrence_byDay.map((d: number) => dayNumberToRRule[d]).join(',');

    const foldLine = (line: string): string => {
      if (line.length <= 75) return line;
      const chunks = [line.slice(0, 75)];
      let i = 75;
      while (i < line.length) { chunks.push(' ' + line.slice(i, i + 74)); i += 74; }
      return chunks.join('\r\n');
    };

    return [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//Deans Okinawan Martial Arts//EN',
      'CALSCALE:GREGORIAN',
      'METHOD:PUBLISH',
      'BEGIN:VEVENT',
      `UID:${uid}`,
      `DTSTAMP:${dtstamp}`,
      `DTSTART;TZID=${cls.timeZone}:${fmt(startDT)}`,
      `DTEND;TZID=${cls.timeZone}:${fmt(endDT)}`,
      `RRULE:FREQ=${cls.recurrence.toUpperCase()};BYDAY=${byDay}`,
      `SUMMARY:${cls.name} - Dean's Okinawan Martial Arts`,
      `DESCRIPTION:${cls.description.replace(/,/g, '\\,')}`,
      `LOCATION:${cls.location.replace(/,/g, '\\,')}`,
      'END:VEVENT',
      'END:VCALENDAR',
    ].map(foldLine).join('\r\n');
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Hydrate each card
    document.querySelectorAll<HTMLElement>('[data-component="CalendarAddKarateClass"]').forEach(card => {
      const cls          = JSON.parse(card.dataset.class ?? '{}');
      const cancelled    = JSON.parse(card.dataset.cancelledDates ?? '[]');
      const id           = card.dataset.id ?? '';
      const linkTemplate = card.dataset.googleLinkTemplate ?? '';

      const { startDT, endDT } = getNextOccurrence(
        cls.recurrence_byDay, cls.startTime, cls.endTime, cancelled
      );

      // Reveal date panel and populate slots
      const datePanel = card.querySelector<HTMLElement>('[data-slot="date-panel"]');
      if (datePanel) datePanel.style.visibility = '';

      card.querySelector<HTMLElement>('[data-slot="day"]')!.textContent =
        String(startDT.getDate());
      card.querySelector<HTMLElement>('[data-slot="month"]')!.textContent =
        startDT.toLocaleString('default', { month: 'short' }).toUpperCase();

      // Patch Google Calendar link — __DATES__ sits outside URLSearchParams so no double-encoding
      const googleLink = card.querySelector<HTMLAnchorElement>('[data-slot="google-calendar-link"]');
      if (googleLink) {
        googleLink.href = linkTemplate.replace('__DATES__', `${fmt(startDT)}/${fmt(endDT)}`);
      }

      // Pre-generate ICS so download is instant
      card.dataset.icsContent = generateICSContent(cls, id, cancelled);
    });

    // Dropdown toggles
    document.querySelectorAll<HTMLButtonElement>('button[data-toggle="calendar-dropdown"]').forEach(button => {
      button.addEventListener('click', () => {
        const dropdown = document.getElementById(button.getAttribute('aria-controls') ?? '');
        if (!dropdown) return;
        const expanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!expanded));
        dropdown.classList.toggle('is-expanded', !expanded);
      });
    });

    document.querySelectorAll<HTMLDivElement>('div[data-component="dropdown"]').forEach(dropdown => {
      dropdown.addEventListener('click', e => {
        if (e.target instanceof HTMLAnchorElement) {
          const toggle = document.querySelector<HTMLButtonElement>(`[aria-controls="${dropdown.id}"]`);
          toggle?.setAttribute('aria-expanded', 'false');
          dropdown.classList.remove('is-expanded');
        }
      });
    });

    // ICS download
    document.querySelectorAll<HTMLButtonElement>('[data-action="download-ics"]').forEach(button => {
      button.addEventListener('click', () => {
        const card       = button.closest<HTMLElement>('[data-component="CalendarAddKarateClass"]');
        const icsContent = card?.dataset.icsContent ?? '';
        const icsName    = card?.dataset.icsName ?? 'event';
        const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8' });
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url; a.download = `${icsName}.ics`; a.click();
        URL.revokeObjectURL(url);
      });
    });
  });
</script>