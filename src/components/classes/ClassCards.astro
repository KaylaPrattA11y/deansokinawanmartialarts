---
import Cards from "../cards/Cards.astro";
import Card from "../cards/Card.astro";
import Button from "../Button.astro";
import { YOUTH_CLASS, ADULT_CLASS, FREE_TRIAL_NAME } from '../../constants';
import CalendarAddKarateClass from "../CalendarAddKarateClass.astro";
import { getCollection } from 'astro:content';

const allAnnouncements = await getCollection('announcements');
const today = new Date();
today.setHours(0, 0, 0, 0);

// Filter to future cancelled dates and group by class name
const youthCancelled = allAnnouncements
  .filter((a) => a.data.className === YOUTH_CLASS.name && a.data.cancelled && new Date(a.data.date) >= today)
  .map((a) => {
    const d = new Date(a.data.date);
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
  });

const adultCancelled = allAnnouncements
  .filter((a) => a.data.className === ADULT_CLASS.name && a.data.cancelled && new Date(a.data.date) >= today)
  .map((a) => {
    const d = new Date(a.data.date);
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
  });
const { headingLevel = 0 } = Astro.props;
---

<Cards cols={2} id="class-cards">
  <Card kanji="子">
    <div class="class-entry">
      <div class="class-age">Ages {YOUTH_CLASS.ages}</div>
      <div class="class-entry-grid">
        <div>
          <CalendarAddKarateClass id="yc-classes" karateClass={YOUTH_CLASS} cancelledDates={youthCancelled} headingLevel={headingLevel} />
          <p class="class-desc">{YOUTH_CLASS.description}</p>
        </div>
        <div>
          <div class="class-tuition">{YOUTH_CLASS.tuition_recurrence} Tuition:</div>
          <ul>
            <li>1 day per week: <strong>${YOUTH_CLASS.tuition[0]}</strong></li>
            <li>2 days per week: <strong>${YOUTH_CLASS.tuition[1]}</strong></li>
          </ul>
        </div>
      </div>
      <div class="class-cta">
        <Button 
          type="button"
          data-interest={YOUTH_CLASS.name}
          aria-haspopup="dialog"
          aria-controls="free-trial-dialog"
        >
          Join {YOUTH_CLASS.name}
        </Button>
      </div>
    </div>
  </Card>
  <Card kanji="武">
    <div class="class-entry">
      <div class="class-age">Ages {ADULT_CLASS.ages}</div>
      <div class="class-entry-grid">
        <div>
          <CalendarAddKarateClass id="ac-classes" karateClass={ADULT_CLASS} cancelledDates={adultCancelled} headingLevel={headingLevel} />
          <p class="class-desc">{ADULT_CLASS.description}</p>
        </div>
        <div>
          <div class="class-tuition">{ADULT_CLASS.tuition_recurrence} Tuition:</div>
          <ul>
            <li>1 day per week: <strong>${ADULT_CLASS.tuition[0]}</strong></li>
            <li>2 days per week: <strong>${ADULT_CLASS.tuition[1]}</strong></li>
          </ul>
        </div>
      </div>
      <div class="class-cta">
        <Button 
          type="button" 
          data-interest={ADULT_CLASS.name}
          aria-haspopup="dialog"
          aria-controls="free-trial-dialog"
        >
          Join {ADULT_CLASS.name}
        </Button>
      </div>
    </div>
  </Card>
</Cards>

<script is:inline define:vars={{FREE_TRIAL_NAME}}>
  const classesSection = document.getElementById('class-cards');

  classesSection?.addEventListener('click', event => {
    const isDialogTrigger = 
      event.target instanceof HTMLButtonElement 
      && event.target.hasAttribute('aria-haspopup') 
      && event.target.getAttribute('aria-haspopup') === 'dialog';
    if (isDialogTrigger) {
      const dialog = document.getElementById('free-trial-dialog');
      const dataInterest = (event.target).getAttribute('data-interest');
      const contactForm = document.forms.namedItem('free-trial-form');
      const interest = contactForm.elements.namedItem('interest');
      const messageTextarea = contactForm.elements.namedItem('message');

      contactForm.reset();
      dialog.showModal();
      if (interest && dataInterest) {
        interest.value = dataInterest;
        interest.dispatchEvent(new Event('change', { bubbles: true }));
      }
      if (messageTextarea) {
        messageTextarea.value = `I am interested in starting my ${FREE_TRIAL_NAME} for ${dataInterest}.`;
      }
      contactForm.dispatchEvent(new Event('change', { bubbles: true }));
    }
  });
</script>

<style>
  @layer components {
    .class-entry {
      container: class-entry / inline-size;
      padding: 2rem 1.5rem;
    }
    .class-entry-grid {
      display: grid;
      gap: 0 2rem;
      @container class-entry (width >= 500px) {
        grid-template-columns: 1.75fr 1fr;
      }
    }
    .class-entry-grid :where(p,ul,h4) {
      margin-block: 1em;
    }
    .class-cta {
      display: grid;
      justify-content: center;
    }
    .class-age {
      font-family: var(--ff-heading);
      font-size: 0.9rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--silver);
      margin-bottom: 1rem;
    }
    .class-name {
      font-family: var(--ff-heading);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--paper);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }
    .class-desc {
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }
    .class-schedule {
      font-family: var(--ff-heading);
      font-size: 0.9rem;
      letter-spacing: 0.2em;
      color: var(--glow-red);
      text-transform: uppercase;
      margin-block: 1em;
    }
    .class-tuition {
      font-family: var(--ff-body);
      font-size: 1rem;
      font-weight: 700;
      line-height: normal;
    }
    .class-entry ul {
      margin-inline-start: 1em;
    }
    ul {
      padding: 0;
      list-style: disc;
      line-height: normal;
    }
    li::marker {
      color: var(--deep-red);
    }
    .class-entry li {
      font-family: var(--ff-heading);
      font-size: 0.875rem;
    }
  }
</style>
