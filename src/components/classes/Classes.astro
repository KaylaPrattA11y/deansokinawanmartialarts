---
import ClassAnnouncements from './ClassAnnouncements.astro';
import ClassCards from './ClassCards.astro';
---

<section class="classes" id="classes">
  <div class="classes-inner">
    <div class="classes-header">
      <div>
        <div class="section-label">Training</div>
        <h2 class="section-title">Classes &amp; Schedule</h2>
      </div>
      <ClassAnnouncements headingLevel={3} />
    </div>
    <ClassCards headingLevel={3} />
  </div>
</section>

<style>
  @layer components {
    .classes {
      --padding-x: 0;
      padding: 2rem var(--padding-x) 0;
      background: var(--stone);
      @container (width >= 900px) {
        --padding-x: 3rem;
        padding: 7rem var(--padding-x);
      }
    }
    .classes-inner {
      container: classes / inline-size;
      max-width: 1200px;
      margin: 0 auto;
    }
    .classes-inner > div {
      @container (width < 900px) {
        padding-inline: 1rem;
      }
    }
    .section-label {
      font-family: var(--ff-heading);
      font-size: 0.9rem;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: var(--silver);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .section-title {
      font-family: var(--ff-heading);
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 700;
      line-height: 1.1;
      color: var(--paper);
      margin-bottom: 2rem;
    }
    .classes-header {
      display: grid;
      @container (width >= 900px) {
        grid-template-columns: 1.5fr 1fr;
      }
      > div:last-child {
        align-self: end;
      }
    }
  }
</style>
