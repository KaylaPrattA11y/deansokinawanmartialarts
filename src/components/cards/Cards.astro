---
interface CardsProps {
  cols?: number;
}

const { cols = 3, ...rest } = Astro.props as CardsProps;
---

<ul class="cards" style={{ '--cols': cols }} {...rest}>
  <slot />
</ul>

<style>
  @layer components {
    ul {
      list-style: none;
      padding-inline-start: 0;
      display: grid;
      margin: 0;
      @container (width >= 900px) {
        justify-content: center;
        grid-template-columns: repeat(var(--cols), 1fr);
      }
    }
  }
</style>
