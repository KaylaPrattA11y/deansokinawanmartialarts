---
import { Icon } from "astro-icon/components";
import { FLAGS } from '../config/site';

export interface GalleryImage {
  mediaType: 'photo' | 'video';
  image?: string;
  vimeoUrl?: string;
  title?: string;
  caption?: string;
  credit?: string;
  slug?: string;
}

interface PhotoGalleryProps {
  images: GalleryImage[];
  title?: string;
}

const { title, images } = Astro.props as PhotoGalleryProps;
const validImages = images.filter(img => 
  (img.mediaType === 'photo' && img.image) || 
  (img.mediaType === 'video' && img.vimeoUrl)
);
---

<section aria-label={title || "Gallery"}>
  {title && <h2 class="gallery-title">{title}</h2>}
  <div class="photo-gallery">
    {validImages.map((img, index) => {
    if (img.mediaType === 'photo' && img.image) {
      return (
        <figure class="media-wrapper">
          <div>
            <img
              src={img.image}
              alt={img.title || ""}
              class="gallery-image"
              loading="lazy"
            />
            {(img.title || img.caption) && (
            <figcaption class="figcaption">
              {img.title && <div class="image-title">{img.title}</div>}
              {img.caption && <div class="image-caption">{img.caption}</div>}
            </figcaption>
            )}
            <button 
              class="lightbox-trigger"
              data-photo-gallery="trigger"
              data-media-type="photo"
              data-index={index}
              data-src={img.image}
              data-title={img.title}
              data-caption={img.caption}
              data-credit={img.credit}
              data-slug={img.slug}
              aria-label={`View ${img.title || 'image'}`}
              type="button"
            >
              <Icon name="fullscreen" size="28px" color="var(--paper)" />
            </button>
          </div>
        </figure>
      )
    }
    if (img.vimeoUrl) {
      // example https://vimeo.com/1110587814
      const videoId = img.vimeoUrl.split('vimeo.com/').pop()?.split('?')[0] || '';
      const src = `https://player.vimeo.com/video/${videoId}`;
      return (
        <div class="media-wrapper">
          <div class="iframe-wrapper">
            <iframe
              title={img.title || "Embedded Content"}
              src={`${src}?controls=0`}
              class="gallery-embed"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              referrerpolicy="strict-origin-when-cross-origin" 
            />
            {(img.title || img.caption) && (
            <div class="figcaption">
              {img.title && <div class="image-title">{img.title}</div>}
              {img.caption && <div class="image-caption">{img.caption}</div>}
              {img.credit && <div class="image-credit">Credit: <strong>{img.credit}</strong></div>}
            </div>
            )}
          </div>
          <button 
            class="lightbox-trigger"
            data-photo-gallery="trigger"
            data-media-type="video"
            data-src={src}
            data-title={img.title}
            data-caption={img.caption}
            data-credit={img.credit}
            data-slug={img.slug}
            aria-label={`View ${img.title || 'video'}`}
            type="button"
          >
            <Icon name="fullscreen" size="28px" color="var(--paper)" />
          </button>
        </div>
      )
    }
    return null;
  })}
  </div>
  <dialog id="gallery-dialog">
    <div class="media-wrapper">
      <div class="video-wrapper d-none">
        <Icon name="spinner" size="56px" color="var(--ash)" />
        <div class="iframe-wrapper">
          <iframe class="v-hidden" title="Embedded Content" src="" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" />
        </div>
      </div>
      <div class="photo-wrapper d-none">
        <Icon name="spinner" size="56px" color="var(--ash)" />
        <img src="" alt="" class="v-hidden" />
      </div>
      <div class="figcaption v-hidden">
        <h1 class="image-title">loading image...</h1>
        <p class="image-caption"></p>
        <small class="image-credit">Credit: <strong></strong></small>
      </div>
      <div role="group" class="image-controls">
        <button 
          class="image-save d-none"
          data-photo-gallery="save"
          aria-label="Save image"
          type="button"
          >
          <Icon name="save" size="28px" />
        </button>
        <button 
          class="image-share d-none"
          data-share="true"
          aria-label="Share media"
          type="button"
        >
          <Icon name="share" size="24px" />
        </button>
        <button 
          class="lightbox-trigger"
          data-photo-gallery="trigger"
          data-action="close"
          aria-label="Close"
          type="button"
        >
          <Icon name="close" size="32px" />
        </button>
      </div>
      {FLAGS.useLightboxControls && (
      <div role="group" class="lightbox-controls">
        <button 
          class="image-prev"
          data-photo-gallery="prev"
          aria-label="Previous image"
          type="button"
          >
          <Icon name="arrow-left" size="28px" color="var(--theme-red)" />
        </button>
        <button 
          class="image-next"
          data-photo-gallery="next"
          aria-label="Next image"
          type="button"
        >
          <Icon name="arrow-right" size="28px" color="var(--theme-red)" />
        </button>
      </div>
      )}
    </div>
  </dialog>
</section>

<script is:inline>
  const dialog = document.getElementById('gallery-dialog');
  let currentIndex = -1;

  function getAllTriggers() {
    return Array.from(document.querySelectorAll('button[data-photo-gallery="trigger"]:not([data-action="close"])'));
  }

  function showItem(btn) {
    const { mediaType, src, title, caption, credit, slug } = btn.dataset;
    if (!mediaType) return;

    const dialogMediaWrapper = dialog.querySelector('.media-wrapper');
    const photoWrapper = dialog.querySelector('.photo-wrapper');
    const videoWrapper = dialog.querySelector('.video-wrapper');
    const dialogImg = dialog.querySelector('img');
    const dialogIframe = dialog.querySelector('iframe');
    const figcaption = dialog.querySelector('.figcaption');
    const dialogTitle = dialog.querySelector('.image-title');
    const dialogCaption = dialog.querySelector('.image-caption');
    const dialogCredit = dialog.querySelector('.image-credit');
    const saveButton = dialog.querySelector('[data-photo-gallery="save"]');
    const shareButton = dialog.querySelector('[data-share="true"]');

    // Reset photo
    dialogImg.classList.replace('v-visible', 'v-hidden');
    figcaption.classList.replace('v-visible', 'v-hidden');
    dialogImg.src = '';
    dialogImg.alt = '';
    dialogImg.dataset.slug = '';
    dialogTitle.textContent = '';
    dialogCaption.textContent = '';
    dialogCaption.hidden = true;
    dialogCredit.firstElementChild.textContent = '';
    dialogCredit.hidden = true;

    // Reset video
    dialogIframe.classList.replace('v-visible', 'v-hidden');
    dialogIframe.src = '';
    dialogIframe.title = 'Embedded Content';

    // Reset shared metadata
    shareButton.dataset.title = '';
    shareButton.dataset.description = '';
    shareButton.dataset.slug = '';

    photoWrapper.classList.toggle('d-none', mediaType !== 'photo');
    videoWrapper.classList.toggle('d-none', mediaType !== 'video');
    saveButton.classList.toggle('d-none', mediaType !== 'photo');

    if (mediaType === 'photo') {
      dialogImg.onload = () => {
        dialogImg.classList.replace('v-hidden', 'v-visible');
        figcaption.classList.replace('v-hidden', 'v-visible');
      };
      dialogImg.src = src || '';
      dialogImg.alt = title || '';
      dialogImg.dataset.slug = slug || '';
    }

    if (mediaType === 'video') {
      dialogIframe.onload = () => {
        dialogIframe.classList.replace('v-hidden', 'v-visible');
        figcaption.classList.replace('v-hidden', 'v-visible');
      };
      dialogIframe.src = `${src}?autoplay=1&muted=1` || '';
      dialogIframe.title = title || 'Embedded Content';
    }

    dialogTitle.textContent = title || '';
    dialogCaption.textContent = caption || '';
    dialogCaption.hidden = !caption;
    dialogCredit.firstElementChild.textContent = credit || '';
    dialogCredit.hidden = !credit;

    shareButton.dataset.title = title || '';
    shareButton.dataset.description = caption || '';
    shareButton.dataset.slug = slug || '';

    dialogMediaWrapper.classList.remove('v-hidden');
  }

  function closeDialog() {
    const dialogMediaWrapper = dialog.querySelector('.media-wrapper');
    const photoWrapper = dialog.querySelector('.photo-wrapper');
    const videoWrapper = dialog.querySelector('.video-wrapper');
    const dialogImg = dialog.querySelector('img');
    const dialogIframe = dialog.querySelector('iframe');
    const figcaption = dialog.querySelector('.figcaption');
    const dialogTitle = dialog.querySelector('.image-title');
    const dialogCaption = dialog.querySelector('.image-caption');
    const dialogCredit = dialog.querySelector('.image-credit');
    const saveButton = dialog.querySelector('[data-photo-gallery="save"]');
    const shareButton = dialog.querySelector('[data-share="true"]');

    dialogMediaWrapper.classList.add('v-hidden');
    photoWrapper.classList.add('d-none');
    videoWrapper.classList.add('d-none');
    saveButton.classList.add('d-none');
    dialogImg.classList.replace('v-visible', 'v-hidden');
    figcaption.classList.replace('v-visible', 'v-hidden');
    dialogImg.src = '';
    dialogImg.alt = '';
    dialogImg.dataset.slug = '';
    dialogTitle.textContent = '';
    dialogCaption.textContent = '';
    dialogCaption.hidden = true;
    dialogCredit.firstElementChild.textContent = '';
    dialogCredit.hidden = true;
    dialogIframe.classList.replace('v-visible', 'v-hidden');
    dialogIframe.src = '';
    dialogIframe.title = 'Embedded Content';
    shareButton.dataset.title = '';
    shareButton.dataset.description = '';
    shareButton.dataset.slug = '';
    currentIndex = -1;
    dialog.close();
  }

  function navigateLightbox(direction) {
    const triggers = getAllTriggers();
    if (triggers.length === 0) return;
    currentIndex = (currentIndex + direction + triggers.length) % triggers.length;
    showItem(triggers[currentIndex]);
  }

  function handleToggleLightbox(btn) {
    const { action } = btn.dataset;

    if (action === 'close' || dialog.open) {
      closeDialog();
      return;
    }

    const triggers = getAllTriggers();
    currentIndex = triggers.indexOf(btn);
    showItem(btn);
    dialog.showModal();
  }

  async function handleSaveImage(btn) {
    const dialog = btn.closest('dialog');
    
    if (!dialog.open) return;
    const dialogImg = dialog.querySelector('img');
    const imageSrc = dialogImg.src;
    const nameOfDownload = dialogImg.alt || 'downloaded-image';

    try {
      // Fetch the image data from the source URL
      const response = await fetch(imageSrc);
      // Convert the response to a Blob object (Binary Large Object)
      const blobImage = await response.blob();
      // Create a temporary URL for the Blob object
      const href = URL.createObjectURL(blobImage);

      // Create a temporary anchor element
      const anchorElement = document.createElement('a');
      anchorElement.href = href;
      anchorElement.download = nameOfDownload; // Set the desired file name for the download

      // Append the anchor to the body, click it programmatically, and then remove it
      document.body.appendChild(anchorElement);
      anchorElement.click();
      document.body.removeChild(anchorElement);

      // Clean up the temporary object URL to free memory
      URL.revokeObjectURL(href);
    } catch (error) {
      console.error('Error downloading image: ', error);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.addEventListener('click', (event) => {
      const triggerButton = event.target.closest('button[data-photo-gallery="trigger"]');
      if (triggerButton) {
        handleToggleLightbox(triggerButton);
        return;
      }

      const saveButton = event.target.closest('button[data-photo-gallery="save"]');
      if (saveButton) {
        handleSaveImage(saveButton);
        return;
      }

      const prevButton = event.target.closest('button[data-photo-gallery="prev"]');
      if (prevButton) {
        navigateLightbox(-1);
        return;
      }

      const nextButton = event.target.closest('button[data-photo-gallery="next"]');
      if (nextButton) {
        navigateLightbox(1);
        return;
      }
    });

    document.addEventListener('keydown', (event) => {
      if (!dialog.open) return;
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        navigateLightbox(-1);
      } else if (event.key === 'ArrowRight') {
        event.preventDefault();
        navigateLightbox(1);
      }
    });
  });
</script>

<style>
  @layer components {
    .lightbox-trigger {
      cursor: pointer;
    }
    dialog {
      border: 0;
      overflow: hidden;
    }
    dialog .media-wrapper {
      inline-size: 100%;
      block-size: 100%;
      max-block-size: 100vh;
      max-block-size: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    dialog .media-wrapper :is(.photo-wrapper, .video-wrapper) {
      inline-size: 100%;
      flex: 1 1 auto;
      min-block-size: 50vh;
      min-block-size: 50dvh;
      max-block-size: 80vh;
      max-block-size: 80dvh;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    dialog :is(.photo-wrapper, .video-wrapper) >  svg {
      position: absolute;
      inset: 50% auto auto 50%;
      translate: -50% -50%;
      z-index: 0;
    }
    dialog img {
      max-inline-size: 100%;
      block-size: 100%;
      max-block-size: 100%;
      object-fit: contain;
      border-radius: 4px;
      position: relative;
      z-index: 1;
    }
    dialog figure {
      inline-size: 100%;
      block-size: 100%;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      overflow: auto;
    }
    dialog figure img {
      flex-shrink: 1;
      min-block-size: 0;
    }
    dialog .figcaption:has(.image-title:not(:empty), .image-caption:not(:empty)) {
      inline-size: 100%;
      display: grid;
      text-align: center;
      justify-items: center;
      align-content: start;
      padding: 2rem 1rem;
      box-sizing: border-box;
      flex: 1 1 auto;
      overflow-y: auto;
      overflow-x: hidden;
      color: var(--paper);
      min-block-size: 0;
    }
    dialog .figcaption :where(h1, p) {
      max-inline-size: 60ch;
    }
    dialog .image-controls {
      display: flex;
      gap: 0.25rem;
      position: absolute;
      z-index: 1;
      justify-content: flex-end;
      padding: 6px 1rem 1rem;
      box-sizing: border-box;
      inset: 0 auto auto 0;
      inline-size: 100%;
      text-shadow: #000000 0px 1.5px 4px;
      background: #000000;
      background: linear-gradient(180deg,rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.35) 30%, rgba(0, 0, 0, 0) 100%);
    }
    dialog .image-controls button {
      color: var(--paper);
      background: none;
    }
    dialog .lightbox-controls {
      display: flex;
      gap: 0.25rem;
      padding-inline: 4px;
      position: absolute;
      z-index: 1;
      justify-content: space-between;
      box-sizing: border-box;
      inset: 50% auto auto 0;
      inline-size: 100%;
      color: var(--ink);
    }
    dialog .lightbox-controls button {
      background: none;
      display: grid;
      place-content: center;
      cursor: pointer;
    }
    dialog [role="group"] button {
      appearance: none;
      margin: 0;
      padding: 0;
      border: 0;
      block-size: 2rem;
      inline-size: 2rem;
    }
    dialog .image-title {
      color: var(--paper);
      font-family: var(--ff-heading);
      font-weight: 700; 
      font-size: 1.25rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      margin: 0;
    }
    dialog .image-caption {
      font-size: 1.15rem;
      line-height: 1.5;
      color: var(--stone);
      max-inline-size: 80ch;
    }
    figure {
      margin: 0;
    }
    .photo-gallery .media-wrapper {
      position: relative;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      background: var(--skeleton-bg);
      background-size: 200% 100%;
      animation: loading 1.5s infinite;
    }
    .photo-gallery figure > div {
      position: relative;
      width: 100%;
      height: 100%;
    }
    .photo-gallery .media-wrapper img {
      background: var(--ink);
    }
    .photo-gallery .media-wrapper .lightbox-trigger {
      appearance: none;
      background: none;
      inline-size: 100%;
      block-size: 100%;
      margin: 0;
      padding: 0;
      border: 0;
    }
    .photo-gallery .media-wrapper .lightbox-trigger svg {
      position: absolute;
      inset: 0 0 auto auto;
    }
    .photo-gallery :where(.figcaption, .lightbox-trigger) {
      position: absolute;
      inset: 0;
      z-index: 1;
    }
    .photo-gallery .figcaption, 
    .photo-gallery .media-wrapper .lightbox-trigger {
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .photo-gallery .figcaption {
      padding: 0.5rem;
      box-sizing: border-box;
      background-color: rgba(0, 0, 0, 0.75);
      display: grid;
      text-align: center;
      place-content: center;
    }
    .photo-gallery .media-wrapper:hover :where(.figcaption, .lightbox-trigger) {
      opacity: 1;
    }
    .media-wrapper > iframe {
      position: relative;
      z-index: 0;
    }
    .photo-gallery .image-title {
      font-family: var(--ff-heading);
      font-weight: 700;
      color: var(--paper);
      margin-block: 0.5em;
      line-height: 1.2;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
    }
    .photo-gallery .image-caption {
      font-size: 0.9rem;
      display: block;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 5;
      overflow: hidden;
    }
    .photo-gallery {
      gap: 1px;
      display: grid;
      @container (width < 600px) {
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        margin-inline-start: calc(var(--padding-x) * -1);
        inline-size: calc(100% + calc(var(--padding-x) * 2));
      }
      @container (width >= 600px) {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      }
    }
    .gallery-image {
      inline-size: 100%;
      block-size: 100%;
      object-fit: cover;
      box-sizing: border-box;
    }
    .photo-gallery .iframe-wrapper {
      position: relative;
      overflow: hidden;
      aspect-ratio: 1;
    }
    .photo-gallery .iframe-wrapper iframe {
      width: 200%;
      height: 200%;
      translate: -25% -25%;
    }
    dialog .iframe-wrapper {
      position: relative;
      width: 100%;
      height: 100%;
      aspect-ratio: 16 / 9;
    }
    dialog .iframe-wrapper iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
  }
</style>
