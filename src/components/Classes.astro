---
import Cards from "./cards/Cards.astro";
import Card from "./cards/Card.astro";
import Button from "./Button.astro";
import { YOUTH_CLASS, ADULT_CLASS, CPR_CLASS } from '../constants';
import CalendarAddKarateClass from "./CalendarAddKarateClass.astro";
---

<section class="classes" id="classes">
  <div class="classes-inner">
    <div>
      <div class="section-label">Training</div>
      <h2 class="section-title">Classes &amp; Schedule</h2>
    </div>
    <Cards>
      <Card kanji="子">
        <div class="class-entry">
          <div class="class-age">Ages {YOUTH_CLASS.ages}</div>
          <div class="class-entry-grid">
            <div>
              <CalendarAddKarateClass id="yc-classes" karateClass={YOUTH_CLASS} />
              <p class="class-desc">
                {YOUTH_CLASS.description}
              </p>
            </div>
            <div>
              <h4>{YOUTH_CLASS.tuition_recurrence} Tuition:</h4>
              <ul>
                <li>1 day per week: <strong>${YOUTH_CLASS.tuition[0]}</strong></li>
                <li>2 days per week: <strong>${YOUTH_CLASS.tuition[1]}</strong></li>
              </ul>
              <Button 
                type="button"
                data-interest={YOUTH_CLASS.name}
                aria-haspopup="dialog"
                aria-controls="free-trial-dialog"
                data-toggle="free-trial-dialog"
              >
                Join {YOUTH_CLASS.name}
              </Button>
            </div>
          </div>
        </div>
      </Card>
      <Card kanji="武">
        <div class="class-entry">
          <div class="class-age">Ages {ADULT_CLASS.ages}</div>
          <div class="class-entry-grid">
            <div>
              <CalendarAddKarateClass id="ac-classes" karateClass={ADULT_CLASS} />
              <p class="class-desc">{ADULT_CLASS.description}</p>
            </div>
            <div>
              <h4>{ADULT_CLASS.tuition_recurrence} Tuition:</h4>
              <ul>
                <li>1 day per week: <strong>${ADULT_CLASS.tuition[0]}</strong></li>
                <li>2 days per week: <strong>${ADULT_CLASS.tuition[1]}</strong></li>
              </ul>
              <Button 
                type="button" 
                data-interest={ADULT_CLASS.name}
                aria-haspopup="dialog"
                aria-controls="free-trial-dialog"
                data-toggle="free-trial-dialog"
              >
                Join {ADULT_CLASS.name}
              </Button>
            </div>
          </div>
        </div>
      </Card>
      <Card kanji="道">
        <div class="class-entry">
          <div class="class-age">Certified Instruction</div>
          <h3 class="class-name">{CPR_CLASS.name}</h3>
          <p class="class-desc">{CPR_CLASS.description}</p>
          <Button 
            type="button"
            data-interest={CPR_CLASS.name}
            data-anchor="contact-form"
          >
            Schedule {CPR_CLASS.name}
          </Button>
        </div>
      </Card>
    </Cards>
  </div>
</section>

<script>
  const classesSection = document.getElementById('classes');

  classesSection?.addEventListener('click', event => {
    if (event.target instanceof HTMLButtonElement) {
      const dataInterest = (event.target as HTMLButtonElement).getAttribute('data-interest');
      const karateInterest = dataInterest && ['Youth Karate', 'Adult Karate'].includes(dataInterest);
      let contactForm = document.forms.namedItem('contact-form') as HTMLFormElement;

      if (karateInterest) {
        contactForm = document.forms.namedItem('free-trial-form') as HTMLFormElement;
      }

      const interest = contactForm.elements.namedItem('interest') as HTMLSelectElement;
      const messageTextarea = contactForm.elements.namedItem('message') as HTMLTextAreaElement;

      contactForm.reset();
      if (interest && dataInterest) {
        interest.value = dataInterest;
        interest.dispatchEvent(new Event('change', { bubbles: true }));
      }
      if (messageTextarea && dataInterest) {
        if (karateInterest) {
          messageTextarea.value = `I am interested in starting my free 7-day trial for ${dataInterest}.`;
        } else {
          messageTextarea.value = `I am interested in ${dataInterest} training.`;
        }
      }
      contactForm.dispatchEvent(new Event('change', { bubbles: true }));
    }
  });
</script>

<style>
  @layer components {
    .classes {
      --padding-x: 0;
      padding: 2rem var(--padding-x) 0;
      background: var(--stone);
      @container (width >= 900px) {
        --padding-x: 3rem;
        padding: 7rem var(--padding-x);
      }
    }
    .classes-inner {
      container: classes / inline-size;
      max-width: 1200px;
      margin: 0 auto;
    }
    .classes-inner > div {
      @container (width < 900px) {
        padding-inline: 1rem;
      }
    }
    .class-entry {
      container: class-entry / inline-size;
      padding: 2rem 1.5rem;
    }
    .class-entry-grid {
      display: grid;
      gap: 0 2rem;
      @container class-entry (width >= 500px) {
        grid-template-columns: 1.35fr 1fr;
      }
    }
    .section-label {
      font-family: var(--ff-heading);
      font-size: 0.9rem;
      letter-spacing: 0.5em;
      text-transform: uppercase;
      color: var(--silver);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .section-title {
      font-family: var(--ff-heading);
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 700;
      line-height: 1.1;
      color: var(--paper);
      margin-bottom: 2rem;
    }
    .class-age {
      font-family: var(--ff-heading);
      font-size: 0.9rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--silver);
      margin-bottom: 1rem;
    }
    .class-name {
      font-family: var(--ff-heading);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--paper);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }
    .class-desc {
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }
    .class-schedule {
      font-family: var(--ff-heading);
      font-size: 0.9rem;
      letter-spacing: 0.2em;
      color: var(--glow-red);
      text-transform: uppercase;
      margin-block: 1em;
    }
    h4 {
      font-family: var(--ff-body);
      font-size: 1rem;
      font-weight: 700;
      margin-block: 0.25em;
      line-height: normal;
    }
    ul {
      margin: 1em 0;
      padding: 0;
      list-style: none;
      display: flex;
      gap: 0 0.5rem;
      flex-wrap: wrap;
      justify-content: space-evenly;
      line-height: normal;
    }
    li {
      font-family: var(--ff-heading);
      font-size: 0.875rem;
    }
  }
</style>
