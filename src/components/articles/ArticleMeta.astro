---
import { Icon } from 'astro-icon/components';
import type { Post } from "../../types";

interface ArticleMetaProps {
  post: Post;
  isStub?: boolean;
  useShareButton?: boolean;
  isHomepage?: boolean;
}

const { post, isStub = false, useShareButton = false, isHomepage = false } = Astro.props as ArticleMetaProps;
---

<header class="post-meta">
  <time datetime={post.data.pubDate.toISOString()} data-is-homepage={isHomepage}>
    {
      new Date(post.data.pubDate).toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })
    }
  </time>
  {isStub ? (
    <>
      {isHomepage ? <h3 class="post-meta-stub-heading">{post.data.title}</h3> : <h2 class="post-meta-stub-heading">{post.data.title}</h2>}
      {post.data.description && <p class="desc">{post.data.description}</p>}
      {post.data.tags && (
      <div class="tags">
        {post.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      )}
      {useShareButton && (
      <button 
        class="d-none"
        type="button" 
        data-share="true"
        data-title={post.data.title}
        data-description={post.data.description}
        data-id={post.id}
      >
        <Icon name="share" /> Share
      </button>
      )}
    </>
  ) : (
    <div class="post-meta-full">
      <div>
        {isHomepage ? <h3 class="post-meta-full-heading">{post.data.title}</h3> : <h1 id="main-content-anchor" class="post-meta-full-heading">{post.data.title}</h1>}
      </div>
      <div class="post-meta-full-info">
        <div>
          {post.data.author && <span class="author">By {post.data.author}</span>}
          {post.data.description && <p class="lead">{post.data.description}</p>}
          {post.data.tags && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          )}
          {useShareButton && (
          <button 
            class="d-none"
            type="button" 
            data-share="true"
            data-title={post.data.title}
            data-description={post.data.description}
            data-id={post.id}
          >
            <Icon name="share" /> Share
          </button>
          )}
        </div>
      </div>
    </div>
  )}
  <slot></slot>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.post-meta time[datetime]').forEach((timeEl) => {
      const dateStr = (timeEl as HTMLTimeElement).getAttribute('datetime');
      const pubDate = dateStr ? new Date(dateStr) : null;
      const isHomepage = (timeEl as HTMLTimeElement).getAttribute('data-is-homepage') === 'true';
      
      // Hide the date if it's a homepage listing and the article is older than 30 days
      const daysThreshold = 30;
      (timeEl as HTMLTimeElement).hidden = !!(isHomepage && pubDate && pubDate < new Date(Date.now() - daysThreshold * 24 * 60 * 60 * 1000));
    });
  });
</script>

<style>
  @layer components {
    :is(h1, h2, h3.post-meta-full-heading, h3.post-meta-stub-heading) {
      font-family: var(--ff-heading);
      font-weight: 700;
      color: var(--paper);
      margin-block: 0.5em;
      line-height: 1.2;
    }
    h1{
      font-size: clamp(2rem, 5vw, 3rem);
    }
    h3.post-meta-full-heading {
      font-size: clamp(1.25rem, 4vw, 2.5rem);
    }
    h2, h3.post-meta-stub-heading {
      font-size: 1.25rem;
    }
    time {
      font-family: var(--ff-heading);
      font-size: 1rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--silver);
      margin-bottom: 1rem;
    }
    button {
      background: none;
      margin: 0;
      padding: 0;
      appearance: none;
      border: 0;
      font-family: var(--ff-heading);
      font-size: 1rem;
      color: var(--paper);
      text-decoration: underline;
      text-decoration-color: var(--bright-red);
      display: flex;
      align-items: center;
      gap: 0.35rem;
      cursor: pointer;
      margin-block-end: 1.5rem;
    }
    .post-meta-full-info {
      display: grid;
      gap: 1rem;
      @container (width > 600px) {
        grid-template-columns: 1fr auto;
        align-items: end;
      }
    }
    .desc, .lead {
      line-height: 1.7;
      color: var(--cream);
      margin-bottom: 1.5rem;
    }
    .desc {
      font-size: 1rem;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 5;
      overflow: hidden;
    }
    .lead {
      font-size: clamp(1rem, 2.5vw, 1.35rem);
    }
    .tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin: 1rem 0;
    }
    .tag:not(:empty) {
      font-family: var(--ff-heading);
      background: var(--stone);
      padding: 0.25rem 0.75rem;
      border-radius: 4px;
      font-size: 0.875rem;
    }
    .author {
      display: block;
      font-family: var(--ff-body);
      font-style: italic;
      font-size: 0.9rem;
      color: var(--cream);
      letter-spacing: 0.05em;
    }
  }
</style>
