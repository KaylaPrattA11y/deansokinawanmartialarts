---
import { Icon } from 'astro-icon/components';
import { CLASSES, YOUTH_CLASS, ADULT_CLASS } from '../constants';
import CalendarAddKarateClass from './CalendarAddKarateClass.astro';
---

<form 
  name="Contact" 
  data-netlify="true" 
  method="POST" 
  id="contact-form"
>
  <input type="hidden" name="form-name" value="Contact" />
  <h2>Send a Message</h2>
  <div class="success-message d-none">
    <p><Icon name="check" size="20px" /> Your message has been sent successfully. We will get back to you at our earliest convenience.</p>
  </div>
  <fieldset>
    <legend class="visually-hidden">Contact Form</legend>
    <div class="form-grid">
      <div class="field">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" autocomplete="name" required />
        <p class="validation">Please enter your name.</p>
      </div>
      <div class="field">
        <label for="phone">Phone</label>
        <input type="tel" id="phone" name="phone" autocomplete="tel" required />
        <p class="validation">Please enter a valid phone number so we can contact you.</p>
      </div>
      <div class="field">
        <label for="email">Email (optional)</label>
        <input type="email" id="email" name="email" autocomplete="email" />
        <p class="validation">Please enter a valid email address.</p>
      </div>
      <div class="field">
        <label for="interest">Interest (optional)</label>
        <select id="interest" name="interest">
          <option value="">Select an option...</option>
          {CLASSES.map((cls: any) => <option value={cls.name}>{cls.name}</option>)}
          <option value="Other">Other</option>
        </select>
      </div>
      <div id="class-schedule" class="d-none">
        <div><strong>Next Class:</strong></div>
        <div id="calendar-add-youth" class="d-none">
          <CalendarAddKarateClass karateClass={YOUTH_CLASS} />
        </div>
        <div id="calendar-add-adult" class="d-none">
          <CalendarAddKarateClass karateClass={ADULT_CLASS} />
        </div>
      </div>
      <fieldset class="field d-none" id="frequency" disabled>
        <legend>Frequency (optional)</legend>
        <div>
          <div class="radio">
            <input type="radio" name="schedule" value="One day per week" id="schedule-1" />
            <label for="schedule-1">One day per week</label>
          </div>
          <div class="radio">
            <input type="radio" name="schedule" value="Two days per week" id="schedule-2" />
            <label for="schedule-2">Two days per week</label>
          </div>
        </div>
      </fieldset>
    </div>
    <div class="field">
      <label for="message">Message</label>
      <textarea id="message" name="message" autocomplete="off" rows="5" required></textarea>
      <p class="validation">Please enter a message.</p>
    </div>
  </fieldset>
  <div class="short-divider"></div>
  <button type="submit">Send Message</button>
  <p class="privacy"><small>We respect your privacy. Your information will never be shared.</small></p>
</form>

<script is:inline define:vars={{ CLASSES }}>
  const form = document.forms.namedItem('contact-form');
  const interestSelect = document.getElementById('interest');
  const classSchedule = document.getElementById('class-schedule');
  const calendarAddYouth = document.getElementById('calendar-add-youth');
  const calendarAddAdult = document.getElementById('calendar-add-adult');
  const fieldset = form?.querySelector('fieldset');
  const frequencyFieldset = document.getElementById('frequency');
  const successMessage = form?.querySelector('.success-message');
  const submitButton = form?.querySelector('button[type="submit"]');
  const SCROLL_OFFSET = 110;

  const scrollToWithOffset = (target) => {
    const top = Math.max(0, target.getBoundingClientRect().top + window.scrollY - SCROLL_OFFSET);
    window.scrollTo({
      top,
      behavior: 'smooth'
    });
  };

  const handleInterestChange = () => {
    const value = interestSelect?.value;
    
    if (value && ['Youth Karate', 'Adult Karate'].includes(value)) {
      frequencyFieldset.disabled = false;
      frequencyFieldset.classList.remove('d-none');
      classSchedule.classList.remove('d-none');
      calendarAddYouth.classList.toggle('d-none', value !== 'Youth Karate');
      calendarAddAdult.classList.toggle('d-none', value !== 'Adult Karate');

    } else {  
      frequencyFieldset.disabled = true;
      frequencyFieldset.classList.add('d-none');
      classSchedule.classList.add('d-none');
    }
  };

  // Listen on the interest select directly
  interestSelect?.addEventListener('change', handleInterestChange);

  form?.addEventListener("change", event => {
    if (event.target instanceof HTMLSelectElement && ['Youth Karate', 'Adult Karate'].includes(event.target.value)) {
      handleInterestChange();
    }
  });

  form?.addEventListener('invalid', event => {
    event.preventDefault();

    const target = event.target;
    if (target instanceof HTMLElement) {
      scrollToWithOffset(target);
      target.focus({ preventScroll: true });
    }
  }, true);

  form?.addEventListener('submit', async event => {
    event.preventDefault();

    if (!form.reportValidity()) {
      return;
    }

    if (!submitButton || !fieldset) return;

    try {
      const formData = new FormData(form);
      const formName = form.getAttribute('name') || 'Contact';
      formData.set('form-name', formName);
      
      // Disable input after data is captured
      submitButton.disabled = true;
      submitButton.textContent = 'Sending...';
      fieldset.disabled = true;
      
      const response = await fetch('/', {
        method: 'POST',
        body: formData
      });
      
      if (response.ok) {
        if (successMessage) {
          successMessage.classList.remove('d-none')
        }
        scrollToWithOffset(form);
      } else {
        alert('Sorry, there was an error sending your message. Please try again.');
      }
    } catch (error) {
      console.error('Error submitting form:', error);
      alert('Sorry, there was an error sending your message. Please try again.');
    } finally {
      submitButton.textContent = 'Message Sent';
    }
  });
</script>

<style>
  @layer components {
    :where(fieldset, button):disabled {
      opacity: 0.5;
    }
    fieldset {
      margin: 0;
      padding: 0;
      border: 0;
      display: block;
      overflow: hidden;
    }
    h2 {
      font-family: var(--ff-heading);
      font-size: clamp(1.25rem, 3.5vw, 2rem);
      font-weight: 700;
      line-height: 1.1;
      color: var(--paper);
      margin-block: 0 1em;
    }
    .success-message {
      background-color: rgba(75, 181, 67, 0.15);
      border: 1px solid rgba(75, 181, 67, 0.3);
      border-radius: 4px;
      padding: 1rem;
      color: #a8e6a3;
      margin-block-end: 1rem;
    }
    .success-message p {
      margin: 0;
      color: #a8e6a3;
      display: flex;
      gap: 0.25rem;
    }
    .privacy {
      text-align: center;
      color: var(--silver);
    }
    .field {
      display: grid;
      gap: 0.15rem;
    }
    form {
      container: form / inline-size;
      display: grid;
      background-color: #2e26228a;
      border-inline-start: 3px solid var(--bright-red);
      padding: 2rem 1rem;
      box-sizing: border-box;
      align-content: start;
      @container (width < 600px) {
        inline-size: calc(100% + calc(var(--padding-x) * 2));
        margin-inline-start: calc(var(--padding-x) * -1);
      }
      @container (width >= 600px) {
        margin-block-start: 2rem;
        border-top-right-radius: 10px;
        border-bottom-right-radius: 10px;
        padding: 2rem;
      }
    }
    .form-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      margin-block-end: 1rem;
    }
    legend {
      display: block;
      padding: 0;
      margin-block-end: 0.3rem;
    }
    label, legend {
      font-style: normal;
      font-size: 1rem;
      font-weight: 700;
      color: var(--silver);
    }
    .radio {
      display: flex;
      gap: 0.5rem;
    }
    .radio label {
      font-weight: 400;
    }
    input[type="radio"] {
      background: var(--ink);
      appearance: none;
      inline-size: 1rem;
      block-size: 1rem;
      border-radius: 50%;
      border: 2px solid var(--silver);
      cursor: pointer;
      flex-shrink: 0;
      margin: 0;
      transition: border-color 0.15s;
      position: relative;
      box-sizing: border-box;
    }
    input[type="radio"]:checked {
      background: var(--bright-red);
      border-color: var(--bright-red);
      box-shadow: inset 0 0 0 3px var(--ink);
    }
    input[type="radio"]:focus-visible {
      outline: 2px solid var(--bright-red);
      outline-offset: 2px;
    }
    input,
    textarea,
    select {
      accent-color: var(--bright-red);
    }
    input:is(:not([type="radio"])),
    textarea,
    select {
      inline-size: 100%;
      background-color: var(--stone);
      box-sizing: border-box;
      padding: 0.5rem;
      border: 1px solid rgba(194,189,181,0.15);
      border-radius: 4px;
      color: var(--paper);
    }
    button[type="submit"] {
      display: inline-block;
      font-family: var(--ff-heading);
      font-weight: 700;
      font-size: 0.8rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s;
      position: relative;
      text-align: center;
      color: var(--paper);
      background: var(--deep-red);
      border: 1px solid rgba(194, 189, 181, 0.15);
      padding: 0.95rem 2.8rem;
    }
    button:not(:disabled) {
      cursor: pointer;
    }
    button[type="submit"]::after {
      content: "";
      position: absolute;
      inset: 3px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      pointer-events: none;
    }
  }
  @layer utilities {
    .validation {
      margin-block-start: 0.25em;
      color: var(--glow-red);
      display: none;
    }
    .field:has(:user-invalid) .validation {
      display: block;
    }
    :user-invalid {
      border-color: var(--glow-red);
    }
  }
</style>