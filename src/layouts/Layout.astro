---
import '@fontsource-variable/cinzel';
import '@fontsource-variable/noto-serif-jp';
import '@fontsource-variable/eb-garamond';
import { AstroSEO } from 'astro-seo-plugin';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../scss/site.scss';
import { BASE_URL, ROUTES, SITE_SEO, SITE_SCHEMA } from '../config/site';
import logo from '../assets/logo.svg';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  robots?: {
    index?: boolean;
    follow?: boolean;
    noarchive?: boolean;
    nosnippet?: boolean;
    maxSnippet?: number;
  };
}

const ogImageUrl = `${Astro.site}og-image.jpg`;
const { title, description = SITE_SEO.description, schema, robots } = Astro.props;
const pageTitle = title ? `${title} | ${SITE_SEO.name.short}` : SITE_SEO.name.long;
const siteOrigin = Astro.site?.toString();

const toAbsoluteUrl = (path: string) => {
  if (!siteOrigin) return undefined;
  return new URL(path, siteOrigin).toString();
};

const websiteUrl = toAbsoluteUrl(BASE_URL);
const logoUrl = toAbsoluteUrl(SITE_SCHEMA.imagePath);
const pageUrl = siteOrigin ? new URL(Astro.url.pathname, siteOrigin).toString() : undefined;

const organizationSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": SITE_SCHEMA.type,
  name: SITE_SCHEMA.name,
  description,
  ...(websiteUrl ? { url: websiteUrl } : {}),
  ...(logoUrl ? { image: logoUrl } : {}),
  ...(SITE_SCHEMA.sameAs.length ? { sameAs: SITE_SCHEMA.sameAs } : {}),
  address: {
    "@type": "PostalAddress",
    addressLocality: SITE_SCHEMA.address.locality,
    addressRegion: SITE_SCHEMA.address.region,
    addressCountry: SITE_SCHEMA.address.country,
  },
};

const webPageSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description,
  ...(pageUrl ? { url: pageUrl } : {}),
  ...(websiteUrl
    ? {
        isPartOf: {
          "@type": "WebSite",
          name: SITE_SCHEMA.name,
          url: websiteUrl,
        },
      }
    : {}),
};

const customSchema = Array.isArray(schema) ? schema : schema ? [schema] : [];
const schemaGraph = [organizationSchema, webPageSchema, ...customSchema];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
    <link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preload" as="image" href={logo.src} fetchpriority="high" />
		<meta name="generator" content={Astro.generator} />
    <AstroSEO
      title={pageTitle}
      description={description}
      openGraph={{
        title: pageTitle,
        description: description,
        image: ogImageUrl,
        type: "website"
      }}
      jsonLd={{
        "@type": "WebPage",
        name: pageTitle,
        description: description
      }}
      robots={{
        index: robots?.index ?? true, // If true, allows search engines to index this page (include it in search results).
        follow: robots?.follow ?? true, // If true, tells search engines to follow links on this page and crawl them.
        noarchive: robots?.noarchive ?? false, // If true, prevents search engines from showing a cached version of this page.
        nosnippet: robots?.nosnippet ?? false, // If true, stops search engines from displaying a text snippet or preview from this page in search results.
        maxSnippet: robots?.maxSnippet ?? 150, // Limits the maximum length of any snippet (if allowed) to 150 characters.
      }}
      additionalLinkTags={[
        { rel: "canonical", href: "#" },
        { rel: "prev", href: Astro.url },
        { rel: "next", href: Astro.url },
        { rel: "alternate", href: Astro.url }
      ]}
      additionalMetaTags={[
        {
        name: "keywords",
        content: SITE_SEO.keywords.join(", ")
        }
      ]}
    />
		<script type="application/ld+json" set:html={JSON.stringify(schemaGraph)}></script>
	</head>
	<body>
    <a href="#main-content-anchor" class="skip-link">Skip to main content</a>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<script is:inline define:vars={{BASE_URL, ROUTES, SITE_SEO}}>
  function closeDropdownMenus() {
    const expandedDropdowns = document.querySelectorAll('[data-component="dropdown"].is-expanded');
      
    expandedDropdowns.forEach(dropdown => {
      const toggleButton = document.querySelector(`[aria-controls="${dropdown.id}"]`);

      dropdown.classList.remove('is-expanded');
      if (toggleButton) {
        toggleButton.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Check every dialog for share buttons
  const dialogs = document.querySelectorAll('dialog');
  
  dialogs.forEach(dialog => {
    // Share buttons within a dialog
    const shareButtons = dialog.querySelectorAll('[data-share="true"]');

    shareButtons.forEach(shareButton => {
      shareButton?.classList.toggle('d-none', !navigator.share);
      shareButton.addEventListener('click', () => {
        if (!navigator.share) return;
        const title = `${shareButton.dataset.title} | ${SITE_SEO.name.short}`;
        const description = shareButton.dataset.description;
        const shareData = {
          title: title,
          text: description ? `${title}\n\n${description}` : title,
          url: `${BASE_URL}${ROUTES.gallery}${shareButton.dataset.slug}/`
        };
        navigator.share(shareData).catch((error) => {
          console.error('Error sharing:', error);
        });
      });
    });
    // Listen for dialog toggle events
    dialog.addEventListener('toggle', () => {
      document.body.classList.toggle('overflow-y-hidden', dialog.open);
    });
  });

  // Share buttons in the main document
  const shareButtons = document.querySelectorAll('[data-share="true"]');

  shareButtons.forEach(shareButton => {
    shareButton.classList.toggle('d-none', !navigator.share);
  });

  document.addEventListener('click', event => {
    // Handle share button clicks
    if (navigator.share) {
      if (event.target instanceof HTMLButtonElement && event.target.matches('[data-share="true"]')) {
        const shareButton = event.target;
        const title = `${shareButton.dataset.title} | ${SITE_SEO.name.short}`;
        const description = shareButton.dataset.description;
        const shareData = {
          title: title,
          text: description ? `${title}\n\n${description}` : title,
          url: `${BASE_URL}${ROUTES.gallery}${shareButton.dataset.slug}/`
        };
        
        navigator.share(shareData).catch((error) => {
          console.error('Error sharing:', error);
        });
      }
    }
    // Handle anchor link clicks for smooth scrolling
    if (event.target instanceof HTMLButtonElement && event.target.hasAttribute('data-anchor')) {
      const anchor = event.target.getAttribute('data-anchor');
      const targetElement = document.getElementById(anchor || '');
      if (targetElement) {
        targetElement.scrollIntoView({ behavior: 'smooth' });
      }
    }
    // Handle clicks outside of a dropdown menu
    if (
      event.target instanceof HTMLElement 
      && !event.target.closest('[data-component="dropdown"].is-expanded') 
      && !event.target.matches('[data-component="dropdown"].is-expanded *')
      && !event.target.closest('[data-toggle="calendar-dropdown"]')
    ) {
      closeDropdownMenus();
    }
  });
  document.addEventListener('keyup', event => {
    if (event.key === 'Escape') {
      closeDropdownMenus();
    }
  });
</script>

<style>
	@layer base {
		html,
		body {
			margin: 0;
			width: 100%;
			height: 100%;
		}
		main {
			container: main / inline-size;
			margin-block-start: var(--header-height);
		}
	}
</style>
