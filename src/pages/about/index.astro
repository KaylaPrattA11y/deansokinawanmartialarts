---
import { Image } from 'astro:assets';
import logo from '../../assets/logo.svg';
import patch from '../../assets/patch.svg';
import Layout from '../../layouts/Layout.astro';
import InteriorPage from "../../components/InteriorPage.astro";
import { BASE_URL, ROUTES } from '../../config/site';
import Button from '../../components/Button.astro';
import DictionaryTerm from '../../components/DictionaryTerm.astro';

const pageDesc = "Dean’s Okinawan Martial Arts and Self Defense provides training in both Shorin Ryu Matsumura Seito and Kobudo.";
---

<Layout title="About" description={pageDesc}>
	<InteriorPage 
    heading={`About | Shorin-Ryu Matsumura Seito`} 
    lead={pageDesc}
  >
    <hr />
    <div class="tenets">
      <span>Character</span>
      <span>Sincerity</span>
      <span>Effort</span>
      <span>Etiquette</span>
      <span>Self-Control</span>
    </div>
    <div class="short-divider" aria-hidden="true"></div>
    <div class="grid grid-intro">
      <section class="content" aria-labelledby="section-1-heading">
        <h2 id="section-1-heading"><DictionaryTerm term="dojo" /> Philosophy and Credentials</h2>
        <p>We are a traditional martial arts school dedicated to preserving the principles and traditions of these ancient arts. Under the direction of <DictionaryTerm term="kyoshi" /> <a href={BASE_URL + ROUTES.instructors + '#kyoshi-wayne-dean'}>Wayne Dean</a>, 8th Dan, we emphasize character, sincerity, effort, etiquette, and self-control — developing each student physically and mentally.</p>
        <p>Each class covers the fundamental techniques, <DictionaryTerm term="kata" />, and their practical applications alongside the rich history of <DictionaryTerm term="okinawa" /> and the origins of these arts. Students also learn self-defense techniques drawn from everyday situations, preparing them to respond confidently to unexpected encounters.</p>
      </section>
      <section class="content" aria-labelledby="section-2-heading">
        <h2 id="section-2-heading">Family-Oriented Classes</h2>
        <p>The dojo offers <a href="/#classes">children's and adult classes</a> in a welcoming, family-oriented atmosphere, and parents are encouraged to observe and participate in their child's training.</p> 
        <p>Kyoshi Wayne Dean holds an 8th Dan and has studied <DictionaryTerm term="shorin-ryu-matsumura-seito" /> Orthodox <DictionaryTerm term="karate" /> since 1971. Both his original and current instructors trained under <a href=`${BASE_URL + ROUTES.news}hohan-soken-the-last-guardian-of-the-old-ways/`>Master Hohan Soken</a> while stationed in Okinawa. He holds a teaching license and dojo charter issued by the Okinawa Konanryu Kohokan Karate-Kobudo-Hakutsuru Kyokai Association, and has operated his Southern Maryland dojo since September 2002, offering classes in Karate, <DictionaryTerm term="kobudo" />, and Self-Defense for children and adults.</p>
        <div class="cta">
          <Button variant="primary" href={BASE_URL + ROUTES.instructors}>
            Meet our Instructors
          </Button>
          <Button variant="secondary" href={BASE_URL + "#classes"}>
            See Class Schedule
          </Button>
        </div>
      </section>
    </div>
    <div class="short-divider"></div>
    <section aria-labelledby="symbology-heading">
      <h2 class="symbology-heading" id="symbology-heading">Dojo Symbology</h2>
      <div class="grid grid-defs">
        <figure>
          <div>
            <Image 
              src={logo} 
              alt="Dojo seal" 
              loading="lazy" 
            />
            <figcaption>
              <h3>Dojo seal</h3>
              <div class="credit">Designed by: Wayne Dean</div>
              <div class="credit">Digitized by: Katharina Fleming</div>
              <dl>
                <dt>Red Octagon</dt>
                <dd>Represents 米, the kanji for "rice", which has eight points. We use this eight-point pattern to align ourselves in kata training.</dd>
                <dt>White Crane (right)</dt>
                <dd>Identifies the style taught in this dojo.</dd>
                <dt>Sai (bottom)</dt>
                <dd>This dojo offers a modest amount of kobudo (weapons) training.</dd>
                <dt>Black three-point swirl (left)</dt>
                <dd>Represents the Ryukyu Islands of Okinawa, symbolizing the connection to the origins of these ancient arts.</dd>
                <dt>Black triangle with kanji 武道 (center)</dt>
                <dd>Means "Martial Arts".</dd>
              </dl>
            </figcaption>
          </div>
        </figure>
        <figure>
          <div>
            <Image 
              src={patch} 
              alt="Dojo patch" 
              loading="lazy" 
            />
            <figcaption>
              <h3>Dojo patch</h3>
              <div class="credit">Designed by: Wayne Dean</div>
              <div class="credit">Digitized by: Katharina Fleming</div>
              <dl>
                <dt>Shorin-Ryu Matsumura Seito</dt>
                <dd>A traditional Okinawan karate style originating from the techniques of <a href={`${BASE_URL + ROUTES.news}sokon-matsumura-warrior-diplomat-and-father-of-shorin-ryu/`}>Bushi Matsumura Sokon</a> (1798-1890), preserved and formalized by Hohan Soken.</dd>
                <dt>Historic temple (top)</dt>
                <dd>The last remaining historic temple associated with this style.</dd>
                <dt>White Crane (bottom)</dt>
                <dd>Identifies the style taught in this dojo.</dd>
                <dt>Kanji 空手 (left and right)</dt>
                <dd>Means "empty hand", referring to the style of martial arts practiced in this dojo.</dd>
              </dl>
            </figcaption>
          </div>
        </figure>
      </div>
      <div class="cta">
        <Button variant="secondary" href={BASE_URL + ROUTES.dictionary}>
          Go to Dictionary
        </Button>
      </div>
    </section>
  </InteriorPage>
</Layout>

<style>
  @layer components {
    .tenets {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-block-end: 2rem;
    }
    .tenets span, .credit {
      font-family: var(--ff-body);
      font-style: italic;
      font-size: 0.9rem;
      color: var(--cream);
      letter-spacing: 0.05em;
    }
    p {
      max-inline-size: 80ch;
    }
    .grid {
      display: grid;
      gap: 3rem 2rem;
    }
    .grid-intro {
      @container (width >= 900px) {
        grid-template-columns: 1fr 1.5fr;
      }
    }
    .img-wrapper {
      margin: 0 auto;
      text-align: center;
      box-sizing: border-box;
      @container (width >= 600px) {
        float: left;
        clear: both;
        margin: 0 1rem 1rem 0;
        max-inline-size: 200px;
      }
    }
    .cta {
      margin-block-start: 2rem;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
    }
    .symbology-heading {
      text-align: center;
    }
    .content :global(> p:first-of-type::first-letter) {
      font-family: var(--ff-heading);
      font-weight: 900;
      color: var(--bright-red);
      font-size: 2.5rem;
      line-height: 1;
    }
    .content :global(h1,h2,h3,h4,h6,h6) {
      font-family: var(--ff-heading);
    }
    .content :global(h1,h2,h3,h4,h6,h6,p,ul,ol) {
      margin-block: 1em;
    }
    .content :global(li) {
      margin-block: 0.5em;
    }
    .content :global(p, ul, ol),
    .content :global(p:where(strong, em, b, i)) {
      font-size: 1.1rem;
      line-height: 1.5;
      color: var(--silver);
    }
    .content :global(li::marker) {
      color: var(--bright-red);
    }
    .content :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 4px;
    }
    .content :global(a:link, a:visited) {
      color: var(--paper);
      text-decoration-color: var(--bright-red);
    }
    figure {
      container: figure / inline-size;
      margin: 0;
      display: grid;
      align-content: start;
    }
    figure > div {
      display: grid;
      gap: 1rem;
      @container (width >= 600px) {
        grid-template-columns: 1fr 1fr;
      }
    }
    figure img {
      max-block-size: 500px;
      block-size: 100%;
      inline-size: 100%;
      margin-inline: auto;
      text-align: center;
    }
  }
</style>
