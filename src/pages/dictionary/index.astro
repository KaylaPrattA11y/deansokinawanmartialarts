---
import Layout from "../../layouts/Layout.astro";
import { BASE_URL, ROUTES } from "../../config/site";

const redirectTarget = `${BASE_URL}${ROUTES.dictionary}1/`;

const pageTitle = "Dictionary";
const pageDesc = "Dictionary entries for Dean's Okinawan Karate, including terms, definitions, and explanations.";
---

<Layout title={pageTitle} description={pageDesc}>
  <script is:inline define:vars={{ redirectTarget }}>
    window.location.replace(redirectTarget);
  </script>
</Layout>
