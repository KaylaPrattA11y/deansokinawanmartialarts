---
import { getCollection, render } from 'astro:content';
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import InteriorPage from "../../components/InteriorPage.astro";
import Instructors from '../../components/instructors/Instructors.astro';
import Instructor from '../../components/instructors/Instructor.astro';

const allInstructors = await getCollection('instructors');
const sorted = allInstructors.sort(
  (a, b) => (a.data.sortOrder ?? 999) - (b.data.sortOrder ?? 999)
);

const instructorImageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/instructors/*.{avif,webp,png,jpg,jpeg}',
  { eager: true }
);

function resolvePhoto(photo?: string): ImageMetadata | string | undefined {
  if (!photo) return undefined;
  const filename = photo.split('/').pop();
  const key = `/src/assets/images/instructors/${filename}`;
  if (instructorImageModules[key]) return instructorImageModules[key].default;
  return photo;
}

const rendered = await Promise.all(
  sorted.map(async (instructor) => {
    const { Content } = await render(instructor);
    return { instructor, Content };
  })
);

const pageTitle = "Meet our Instructors";
const pageDesc = "Expert Shorin-Ryu Matsumura Seito instructors with decades of Okinawan karate experience. Direct lineage to Master Hohan Soken. Youth and adult classes.";
---

<Layout title={pageTitle} description={pageDesc}>
	<InteriorPage 
    heading={pageTitle} 
    lead={pageDesc}
  >
    <hr />
    <Instructors>
      {rendered.map(({ instructor, Content }) => (
        <Instructor
          id={instructor.id}
          name={instructor.data.name}
          title={instructor.data.title}
          rank={instructor.data.rank}
          img={resolvePhoto(instructor.data.photo)}
          imgAspectRatio={instructor.data.photoOrientation === 'Landscape' ? '4 / 3' : '3 / 4'}
          featured={instructor.data.featured}
        >
          <Content />
        </Instructor>
      ))}
    </Instructors>
  </InteriorPage>
</Layout>
