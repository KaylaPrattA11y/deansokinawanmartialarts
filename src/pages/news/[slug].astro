---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Article from '../../components/articles/Article.astro';
import { SITE_SEO } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const siteOrigin = Astro.site?.toString();

const toAbsoluteUrl = (path: string) => {
  if (!siteOrigin) return undefined;
  return new URL(path, siteOrigin).toString();
};

const articleUrl = siteOrigin ? new URL(Astro.url.pathname, siteOrigin).toString() : undefined;
const articleImageUrl = post.data.image ? toAbsoluteUrl(post.data.image) : undefined;
const publisherLogoUrl = toAbsoluteUrl('/logo.png');

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description ? post.data.description : SITE_SEO.description,
  datePublished: new Date(post.data.pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: post.data.author ? post.data.author : SITE_SEO.name.short,
  },
  publisher: {
    "@type": "Organization",
    name: SITE_SEO.name.short,
    ...(publisherLogoUrl
      ? {
          logo: {
            "@type": "ImageObject",
            url: publisherLogoUrl,
          },
        }
      : {}),
  },
  ...(articleUrl
    ? {
        mainEntityOfPage: articleUrl,
        url: articleUrl,
      }
    : {}),
  ...(articleImageUrl ? { image: articleImageUrl } : {}),
};
---

<Layout 
  title={`${post.data.title} | ${SITE_SEO.name.long}`} 
  description={post.data.description ? post.data.description : SITE_SEO.description}
  schema={articleSchema}
>
  <Article {post} />
</Layout>
