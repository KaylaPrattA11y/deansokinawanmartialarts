---
import Layout from "../../layouts/Layout.astro";
import { BASE_URL, ROUTES } from "../../config/site";

const redirectTarget = `${BASE_URL}${ROUTES.news}1/`;

const pageTitle = "News & Updates";
const pageDesc = "Dojo news, belt promotions, seminar announcements, and training updates from Dean's Okinawan Karate, Shorin-Ryu Matsumura Seito, in Hollywood, Maryland.";
---

<Layout title={pageTitle} description={pageDesc}>
  <script is:inline define:vars={{ redirectTarget }}>
    window.location.replace(redirectTarget);
  </script>
</Layout>