---
// Admin page for Decap CMS
---

<!doctype html>
<html lang="EN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Content Manager</title>
    <!-- Custom styles for responsive Decap CMS. See https://manikumar.in/blog/mobile-optimized-decap-netlify-cms/ -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/hithismani/responsive-decap@main/dist/responsive.css">
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script is:inline>
      console.log('=== Admin page script running ===');
      
      // Wait for CMS to be ready
      let attempts = 0;
      const registerStyles = setInterval(() => {
        attempts++;
        console.log(`Attempt ${attempts}: Checking for CMS...`);
        
        if (window.CMS) {
          console.log('CMS found!', window.CMS);
          
          if (window.CMS.registerPreviewStyle) {
            window.CMS.registerPreviewStyle(`
              img {
                max-width: 100% !important;
                height: auto !important;
                display: block !important;
                margin: 1rem 0 !important;
              }
              body {
                padding: 1rem !important;
                max-width: 900px !important;
                margin: 0 auto !important;
              }
            `, { raw: true });
            console.log('✓ Preview styles registered!');
          } else {
            console.log('CMS.registerPreviewStyle not available');
            console.log('Available:', Object.keys(window.CMS));
          }
          
          clearInterval(registerStyles);
        }
        
        if (attempts > 20) {
          console.error('CMS never loaded after 20 attempts');
          clearInterval(registerStyles);
        }
      }, 200);
    </script>
  </head>
  <body>
    <script>
      interface NetlifyWindow extends Window {
        netlifyIdentity: {
          on: (event: string, callback: (user: unknown) => void) => void;
          open: () => void;
        };
      }
      if ((window as unknown as NetlifyWindow).netlifyIdentity) {
        (window as unknown as NetlifyWindow).netlifyIdentity.on("init", user => {
          if (!user) {
            (window as unknown as NetlifyWindow).netlifyIdentity.open();
          }
        });
      }
    </script>
  </body>
</html>

<style is:inline>
  @media (max-width: 799px) {
    .css-ys2s0e-DateTimeControl {
      flex-wrap: wrap !important;
    }
    .css-tp3lu5-LibraryTop,
    .css-c5ftz9-StyledModal {
      padding: 0 !important;
      min-width: 100dvw !important;
      min-height: 100dvh !important;
      width: 100% !important;
      height: 100% !important;
      max-width: unset !important;
    }
    .css-1ipka12-CardGridContainer > div > div {
      padding-block-end: 10rem !important;
    }
    .css-184s0iy-CloseButton-button-button {
      inset: 0 auto auto 0;
    }
    .css-lqsztn-ButtonsContainer,
    .css-gxsmc8-RowContainer {
      display: block !important;
    }
    .css-1cx9csd {
      display: block !important;
    }
    .css-bfotx5-UploadButton-button-button-default-default-disabled-disabled-button-button-gray-gray,
    .css-1ceeuvy-ActionButton-button-button-default-default-disabled-disabled-button-button {
      margin: 0 2px;
    }
    
  }
</style>
