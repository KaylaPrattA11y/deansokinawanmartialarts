---
// Admin page for Decap CMS
---

<!doctype html>
<html lang="EN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Content Manager</title>
    <!-- Custom styles for responsive Decap CMS. See https://manikumar.in/blog/mobile-optimized-decap-netlify-cms/ -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script is:inline>
      function styleAuthPage() {
        const section = document.querySelector('section');
        console.log("styleAuthPage: section found:", section);
        if (section && !section.querySelector('img[alt="Logo"]')) {
          const img = document.createElement('img');
          img.src = `/src/assets/logo.png`;
          img.alt = `Dean's Okinawan Martial Arts & Self Defense`;
          img.className = "auth-logo";
          section.prepend(img);
          console.log("✓ Logo added to auth page");
        }
      }

      function waitForAuthPage() {
        // Poll for the auth section element
        let attempts = 0;
        const checkInterval = setInterval(() => {
          attempts++;
          const section = document.querySelector('section');
          
          if (section) {
            console.log("✓ Auth section found, styling...");
            styleAuthPage();
            clearInterval(checkInterval);
          } else if (attempts > 50) {
            console.log("Auth section not found after 50 attempts");
            clearInterval(checkInterval);
          }
        }, 100);
      }

      console.log("=== Admin page script running ===");

      // Wait for CMS to be ready
      let attempts = 0;
      const registerStyles = setInterval(() => {
        attempts++;
        console.log(`Attempt ${attempts}: Checking for CMS...`);

        if (window.CMS) {
          console.log("CMS found!", window.CMS);

          // Start watching for auth page
          waitForAuthPage();

          if (window.CMS.registerPreviewStyle) {
            window.CMS.registerPreviewStyle(
              `
              img {
                max-width: 100% !important;
                height: auto !important;
                display: block !important;
                margin: 1rem 0 !important;
              }
              body {
                padding: 1rem !important;
                max-width: 900px !important;
                margin: 0 auto !important;
              }
            `,
              { raw: true },
            );
            console.log("✓ Preview styles registered!");
          } else {
            console.log("CMS.registerPreviewStyle not available");
            console.log("Available:", Object.keys(window.CMS));
          }

          clearInterval(registerStyles);
        }

        if (attempts > 20) {
          console.error("CMS never loaded after 20 attempts");
          clearInterval(registerStyles);
        }
      }, 200);
    </script>
  </head>
  <body>
    <script>
      interface NetlifyWindow extends Window {
        netlifyIdentity: {
          on: (event: string, callback: (user: unknown) => void) => void;
          open: () => void;
        };
      }
      if ((window as unknown as NetlifyWindow).netlifyIdentity) {
        (window as unknown as NetlifyWindow).netlifyIdentity.on(
          "init",
          (user) => {
            if (!user) {
              (window as unknown as NetlifyWindow).netlifyIdentity.open();
            }
          },
        );
      }
    </script>
  </body>
</html>

<style is:inline>
