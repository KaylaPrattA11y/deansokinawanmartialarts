---
import { Image } from "astro:assets";
import powImage from "../assets/404-pow.jpg";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found"
  description="The page you are looking for could not be found."
>
  <div class="grid">
    <div>
      <Image 
        src={powImage} 
        alt="A white belt being comically punched in the face. POW!" 
        width={880}
        height={1168}
        class="pow"
      />
    </div>
    <div>
      <h1>404: Page Not Found</h1>
      <p>Watch out! The page you are looking for does not exist.</p>
    </div>
  </div>
</Layout>

<style>
  @layer components {
    .grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: 1fr 1fr;
      @container (width >= 880px) {
        gap: 2rem;
        grid-template-columns: auto 1fr;
      }
    }
    .pow {
      max-block-size: calc(100dvh - var(--header-height));
      inline-size: 100%;
      block-size: 100%;
    }
    h1 {
      font-size: clamp(1.6rem, 4.5vw, 4rem);
    }
    p {
      font-size: clamp(1.1rem, 4.5vw, 1.5rem);
    }
  }
</style>
